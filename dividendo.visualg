algoritmo "dividendos"

var
   dy: real

inicio
   escreva("Digite o valor do Dividend Yield: ")
   leia(dy)

   se (dy > 6) entao
      escreval("Estratégia de Renda Passiva OK")
   senao
      se (dy >= 4) e (dy <= 6) entao
         escreval("Atenção: Rendimento Médio")
      senao
         escreval("Rendimento Baixo")
      fimse
   fimse

fimalgoritmo