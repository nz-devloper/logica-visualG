algoritmo "cripto"

var
  nome: caractere
  variacao: real

inicio
  escreva("Digite o nome da criptomoeda: ")
  leia(nome)

  escreva("Digite a variação (%): ")
  leia(variacao)

  se (variacao > 10) entao
    escreval("Alta Relevante")
  senao
    se (variacao < -10) entao
      escreval("Correção Forte")
    senao
      escreval("Estabilidade")
    fimse
  fimse

fimalgoritmo