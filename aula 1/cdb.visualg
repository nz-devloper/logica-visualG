algoritmo "cdb"

var
   valor, taxa: real
   meses: inteiro

inicio
   escreva("Digite o valor que deseja investir: ")
   leia(valor)

   escreva("Digite o prazo em meses: ")
   leia(meses)

   se (meses > 12) entao
      taxa <- 12
   senao
      taxa <- 8
   fimse

   escreval("Taxa aplicada: ", taxa, "% ao ano")

fimalgoritmo