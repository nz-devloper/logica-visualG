algoritmo "cashback"

var
  valor, retorno: real

inicio
  escreva("Digite o valor da compra: ")
  leia(valor)

  se (valor > 500) entao
    retorno <- valor * 0.10
  senao
    se (valor >= 200) entao
      retorno <- valor * 0.05
    senao
      retorno <- 0
    fimse
  fimse

  escreval("Cashback: R$ ", retorno)

fimalgoritmo