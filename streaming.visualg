algoritmo "streaming"

var
   telas: inteiro

inicio
   escreva("Quantas telas deseja usar? ")
   leia(telas)

   escolha telas
      caso 1
         escreval("Plano Mobile")
      caso 2
         escreval("Plano Padrão")
      caso 4
         escreval("Plano Premium")
      outrocaso
         escreval("Opção inválida")
   fimescolha

fimalgoritmo